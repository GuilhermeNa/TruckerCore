<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_navigation"
    app:startDestination="@+id/nav_home">

    <fragment
        android:id="@+id/nav_home"
        android:name="com.example.truckercore.business_admin.layers.presentation.main.fragments.home.HomeFragment"
        android:label="@string/menu_trucker"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/nav_business"
        android:name="com.example.truckercore.business_admin.layers.presentation.main.fragments.business.BusinessFragment"
        android:label="@string/business"
        tools:layout="@layout/fragment_business" >
        <action
            android:id="@+id/action_nav_business_to_editBusinessFragment"
            app:destination="@id/nav_edit_business"
            app:launchSingleTop="false" />
    </fragment>
    <fragment
        android:id="@+id/nav_fines"
        android:name="com.example.truckercore.business_admin.layers.presentation.main.fragments.fine.FineFragment"
        android:label="@string/fines"
        tools:layout="@layout/fragment_fine" />
    <fragment
        android:id="@+id/nav_fleet"
        android:name="com.example.truckercore.business_admin.layers.presentation.main.fragments.fleet.FleetFragment"
        android:label="@string/fleet"
        tools:layout="@layout/fragment_fleet" />
    <fragment
        android:id="@+id/nav_settings"
        android:name="com.example.truckercore.business_admin.layers.presentation.main.fragments.settings.SettingsFragment"
        android:label="@string/settings"
        tools:layout="@layout/fragment_settings" />
    <fragment
        android:id="@+id/nav_messages"
        android:name="com.example.truckercore.layers.presentation.common.fragments.message_center.MessagesFragment"
        android:label="@string/messages"
        tools:layout="@layout/fragment_messages" />
    <fragment
        android:id="@+id/nav_profile"
        android:name="com.example.truckercore.layers.presentation.common.fragments.profile.ProfileFragment"
        android:label="@string/profile"
        tools:layout="@layout/fragment_profile" />
    <action
        android:id="@+id/action_global_nav_messages"
        app:destination="@id/nav_messages"
        app:launchSingleTop="true" />
    <action
        android:id="@+id/action_global_nav_profile"
        app:destination="@id/nav_profile"
        app:launchSingleTop="true" />
    <fragment
        android:id="@+id/nav_edit_business"
        android:name="com.example.truckercore.business_admin.layers.presentation.main.fragments.edit_business.EditBusinessFragment"
        android:label="@string/edit_business"
        tools:layout="@layout/fragment_edit_business" />

    <navigation android:id="@+id/employee_navigation"
        app:startDestination="@id/nav_employees">
        <fragment
            android:id="@+id/nav_edit_employee"
            android:name="com.example.truckercore.business_admin.layers.presentation.main.fragments.edit_employee.EditEmployeeFragment"
            android:label="@string/edit_employee>"
            tools:layout="@layout/fragment_edit_employee">
            <argument
                android:name="id"
                app:argType="string"
                app:nullable="true" />
        </fragment>
        <fragment
            android:id="@+id/nav_employee"
            android:name="com.example.truckercore.business_admin.layers.presentation.main.fragments.employee.EmployeeFragment"
            android:label="@string/employee"
            tools:layout="@layout/fragment_employee"/>
        <fragment
            android:id="@+id/nav_employees"
            android:name="com.example.truckercore.business_admin.layers.presentation.main.fragments.employees.EmployeesFragment"
            android:label="@string/employee"
            tools:layout="@layout/fragment_employees">
            <action
                android:id="@+id/action_nav_employees_to_employeeTypeFragment"
                app:destination="@id/employeeTypeFragment" />
            <action
                android:id="@+id/action_nav_employees_to_nav_employee"
                app:destination="@id/nav_employee" />
        </fragment>
        <fragment
            android:id="@+id/employeeTypeFragment"
            android:name="com.example.truckercore.business_admin.layers.presentation.main.fragments.employee_type.EmployeeTypeFragment"
            android:label="fragment_employee_type"
            tools:layout="@layout/fragment_employee_type" >
            <argument
                android:name="id"
                app:argType="string" />
            <action
                android:id="@+id/action_employeeTypeFragment_to_nav_edit_employee"
                app:destination="@id/nav_edit_employee" />
        </fragment>
    </navigation>

</navigation>